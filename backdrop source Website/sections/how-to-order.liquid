{% comment %}
  CUSTOM SECTION - HOW TO ORDER
  Updated: Reduced heading size by 25% (to 21px) and set top/bottom padding to 0px.
{% endcomment %}

<style>
  :root {
    --hto-bg: #ffffff;
    --hto-title-color: #172A4F;
    --hto-text-color: #666666;
    --hto-circle-bg: #FDE4DD; 
    --hto-font: 'AvenirNextLTPro', sans-serif, Arial;
  }

  .how-to-order-section {
    background-color: var(--hto-bg);
    padding: 0; /* Changed from 60px 0 to 0 */
    font-family: var(--hto-font);
  }

  .hto-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    text-align: center;
  }

  .hto-title {
    color: var(--hto-title-color);
    font-size: 21px; /* Changed from 28px to 21px (3/4 size) */
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-top: 0;
    margin-bottom: 40px;
  }

  .hto-steps {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 20px;
    flex-wrap: nowrap;
  }

  .hto-step {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 0; 
  }

  .hto-icon-wrapper {
    width: 80px;
    height: 80px;
    background-color: var(--hto-circle-bg);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 15px;
    flex-shrink: 0;
  }

  .hto-icon-wrapper img {
    width: 45%;
    height: 45%;
    object-fit: contain;
  }

  .hto-text {
    color: var(--hto-text-color);
    font-size: 14px;
    line-height: 1.4;
    font-weight: 500;
    margin: 0;
    padding: 0 5px;
  }

  /* --- MOBILE RESPONSIVENESS --- */
  @media (max-width: 900px) {
    .how-to-order-section {
      padding: 0; /* Changed from 40px 0 to 0 */
    }

    .hto-container {
      padding: 0 10px; 
    }

    .hto-title {
      font-size: 16px; /* Scaled down for mobile proportionally */
      margin-bottom: 30px;
    }

    .hto-steps {
      gap: 6px; 
      justify-content: space-between;
    }

    .hto-icon-wrapper {
      width: 45px; 
      height: 45px;
      margin-bottom: 8px;
    }

    .hto-text {
      font-size: 9px; 
      line-height: 1.2;
      padding: 0;
      word-wrap: break-word;
      hyphens: auto;
    }
  }

  @media (max-width: 400px) {
    .hto-icon-wrapper {
      width: 40px;
      height: 40px;
    }
    .hto-text {
      font-size: 8.5px;
    }
    .hto-steps {
      gap: 4px;
    }
  }
</style>

<div class="how-to-order-section">
  <div class="hto-container">
    
    {% if section.settings.title != blank %}
      <h2 class="hto-title">{{ section.settings.title }}</h2>
    {% endif %}

    <div class="hto-steps">
      {% for block in section.blocks %}
        <div class="hto-step" {{ block.shopify_attributes }}>
          
          <div class="hto-icon-wrapper">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.title | escape }}" loading="lazy">
            {% else %}
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2c3e50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                <polyline points="21 15 16 10 5 21"></polyline>
              </svg>
            {% endif %}
          </div>
          
          {% if block.settings.title != blank %}
            <p class="hto-text">{{ block.settings.title }}</p>
          {% endif %}
          
        </div>
      {% endfor %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "How to Order",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "HOW TO ORDER?"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Order Step",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon/Image (Transparent PNG recommended)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step Description",
          "default": "Select Your Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How to Order",
      "blocks": [
        { "type": "step", "settings": { "title": "Select Your Product" } },
        { "type": "step", "settings": { "title": "Choose Size, Options & Add-ons" } },
        { "type": "step", "settings": { "title": "Upload Artwork or Request Design Help" } },
        { "type": "step", "settings": { "title": "Checkout & Receive Email Proof" } },
        { "type": "step", "settings": { "title": "Approve Your Artwork" } },
        { "type": "step", "settings": { "title": "We Print & Ship to Your Door" } }
      ]
    }
  ]
}
{% endschema %}