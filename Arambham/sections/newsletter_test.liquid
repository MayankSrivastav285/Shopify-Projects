{% comment %}
  PIXEL PERFECT - NEWSLETTER
  1. Functional: Uses Shopify's 'form' tag so emails actually go to your "Customers" list.
  2. Design: Dark background (#111820) with white contrast inputs.
  3. Layout: Centered flex layout for the input and button row.
{% endcomment %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    color: #FFFFFF;
  }

  .newsletter-container {
    max-width: 700px; /* Narrow width for focus */
    margin: 0 auto;
    text-align: center;
    padding: 0 20px;
  }

  .newsletter-heading {
    font-size: 36px;
    font-weight: 500;
    margin-bottom: 16px;
    letter-spacing: -0.01em;
    color: #FFFFFF;
  }

  .newsletter-subtext {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 32px;
    line-height: 1.5;
    color: #FFFFFF;
  }

  /* FORM STYLES */
  .newsletter-form {
    display: flex;
    justify-content: center;
    gap: 12px;
    max-width: 500px;
    margin: 0 auto;
    position: relative;
  }

  .newsletter-input {
    flex-grow: 1;
    padding: 16px;
    border: 1px solid transparent;
    border-radius: 4px;
    font-size: 16px;
    color: #000000;
    background-color: #FFFFFF;
    outline: none;
  }

  .newsletter-input:focus {
    border-color: #cccccc;
  }

  .newsletter-btn {
    padding: 16px 32px;
    background-color: #FFFFFF;
    color: #000000;
    border: none;
    border-radius: 4px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }

  .newsletter-btn:hover {
    opacity: 0.9;
  }

  .newsletter-disclaimer {
    margin-top: 16px;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.5);
  }

  /* SUCCESS MESSAGE */
  .form-status {
    margin-bottom: 20px;
    font-size: 14px;
    color: #4cd964;
  }

  /* MOBILE */
  @media screen and (max-width: 600px) {
    .newsletter-form {
      flex-direction: column;
    }
    .newsletter-btn {
      width: 100%;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  <div class="newsletter-container">
    
    <h2 class="newsletter-heading">{{ section.settings.heading }}</h2>
    <p class="newsletter-subtext">{{ section.settings.subtext }}</p>

    {%- form 'customer', class: 'newsletter-form-wrapper' -%}
      {%- if form.posted_successfully? -%}
        <p class="form-status" autofocus>
          Thanks for subscribing! Check your email for confirmation.
        </p>
      {%- endif -%}

      <div class="newsletter-form">
        <input type="hidden" name="contact[tags]" value="newsletter">
        
        <input
          id="NewsletterForm--{{ section.id }}"
          type="email"
          name="contact[email]"
          class="newsletter-input"
          value="{{ form.email }}"
          aria-required="true"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
          placeholder="Enter your email"
          required
        >
        
        <button type="submit" class="newsletter-btn" name="commit">
          Subscribe
        </button>
      </div>

      <p class="newsletter-disclaimer">
        {{ section.settings.disclaimer }}
      </p>
    {%- endform -%}

  </div>
</div>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Stay Updated"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Subscribe to our newsletter for exclusive offers, new arrivals, and style inspiration."
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "We respect your privacy. Unsubscribe at any time."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#111820"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 40,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 40,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}