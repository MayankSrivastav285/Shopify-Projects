{% comment %}
  PIXEL PERFECT - HERO FIX (RGBA METHOD)
  1. Fix: Uses 'rgba(0,0,0, 0.X)' for the background color. This forces darkness.
  2. Fix: Ensures the overlay is absolutely positioned over the image.
{% endcomment %}

{%- style -%}
  .section-{{ section.id }}-hero {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #FFFFFF;
    overflow: hidden;
    margin-top: 0; 
  }

  /* HEIGHTS */
  .hero-height-small { height: 40vh; min-height: 400px; }
  .hero-height-medium { height: 60vh; min-height: 500px; } 
  .hero-height-large { height: 80vh; min-height: 600px; }

  /* IMAGE */
  .hero-bg-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0; 
  }

  /* OVERLAY */
  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1; /* Sits on top of image */
    pointer-events: none;
    /* Background color is handled inline below */
  }

  /* TEXT */
  .hero-content {
    position: relative;
    z-index: 2; /* Sits on top of overlay */
    max-width: 800px;
    padding: 0 20px;
  }

  .hero-title {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    font-size: 64px;
    font-weight: 500;
    margin: 0 0 16px 0;
    color: #FFFFFF;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .hero-subtitle {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    font-size: 20px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.95);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.5;
  }
  
  @media screen and (max-width: 768px) {
    .section-{{ section.id }}-hero { height: 50vh; min-height: 350px; }
    .hero-title { font-size: 42px; }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-hero hero-height-{{ section.settings.section_height }}">
  
  {%- if section.settings.image != blank -%}
    {{ section.settings.image | image_url: width: 2400 | image_tag: class: 'hero-bg-image', loading: 'eager' }}
  {%- else -%}
    {{ 'lifestyle-2' | placeholder_svg_tag: 'hero-bg-image' }}
  {%- endif -%}

  {%- comment -%} 
    THE FIX: Calculate decimal (e.g., 0.4) and put it inside rgba() 
  {%- endcomment -%}
  {%- assign overlay_alpha = section.settings.overlay_opacity | divided_by: 100.0 -%}
  <div class="hero-overlay" style="background-color: rgba(0, 0, 0, {{ overlay_alpha }});"></div>

  <div class="hero-content">
    {%- if section.settings.title != blank -%}
      <h1 class="hero-title">{{ section.settings.title | escape }}</h1>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}
      <p class="hero-subtitle">{{ section.settings.subtext | escape }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "About Hero Banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background Image" },
    { "type": "select", "id": "section_height", "label": "Height", "options": [ { "value": "small", "label": "Small" }, { "value": "medium", "label": "Medium" }, { "value": "large", "label": "Large" } ], "default": "medium" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 90, "step": 5, "unit": "%", "label": "Darkness %", "default": 40 },
    { "type": "text", "id": "title", "label": "Heading", "default": "About ATELIER" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Crafting timeless pieces." }
  ],
  "presets": [ { "name": "About Hero Banner" } ]
}
{% endschema %}