<p style="text-align: {{ section.settings.title_alignment }};">
  {{ section.settings.title }}
</p>

<div style = "display: flex; justify-content:center; gap: 20px;">
  {% for block in section.blocks %}
    {% if block.type == "promotion" %}
      <div style="display: flex; flex-direction: column; align-items: center;">    
        <h2 style="text-align: center;"> {{ block.settings.title }} </h2>
        {{ block.settings.image | image_url: width: 500 | image_tag }}
      </div>
    {% endif %}
  {% endfor %}
</div>

{% schema %}
{
  "name": "Promotion",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Promotion"
    },
    {
      "type": "select",
      "id": "title_alignment",
      "label": "Title alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    }
  ],
  "blocks": [
    {
      "name": "Promotion Block",
      "type": "promotion",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Best Offer"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    { "name": "Promotion" }
  ]
}
{% endschema %}