{% comment %}
  PIXEL PERFECT - FOOTER
  1. Layout: 4-Column Grid (Brand, Menu, Menu, Menu).
  2. Socials: Embedded SVGs for clean, scalable icons.
  3. Typography: Clean, uppercase headings with ample spacing.
{% endcomment %}

{%- style -%}
  .footer-wrapper {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding-top: 80px;
    padding-bottom: 40px;
    border-top: 1px solid #E5E5E5;
  }

  .footer-container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* MAIN GRID */
  .footer-grid {
    display: grid;
    /* First col is 1.5x wider for the brand description */
    grid-template-columns: 1.5fr 1fr 1fr 1fr; 
    gap: 40px;
    margin-bottom: 80px;
  }

  /* HEADINGS & TEXT */
  .footer-heading {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 24px;
    letter-spacing: 0.05em;
    color: {{ section.settings.heading_color }};
  }

  .footer-text {
    font-size: 14px;
    line-height: 1.6;
    color: {{ section.settings.text_color }};
    max-width: 300px;
    margin-bottom: 24px;
  }

  /* LINK LISTS */
  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: 12px;
  }

  .footer-links a {
    text-decoration: none;
    color: {{ section.settings.text_color }};
    font-size: 14px;
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: #000000;
    text-decoration: underline;
  }

  /* SOCIAL ICONS */
  .footer-socials {
    display: flex;
    gap: 20px;
  }

  .social-icon {
    width: 20px;
    height: 20px;
    fill: currentColor;
    color: {{ section.settings.text_color }};
    transition: opacity 0.2s ease;
  }

  .social-icon:hover {
    opacity: 0.7;
  }

  /* COPYRIGHT BAR */
  .footer-bottom {
    border-top: 1px solid #EEEEEE;
    padding-top: 32px;
    text-align: center;
    font-size: 13px;
    color: #888888;
  }

  /* MOBILE RESPONSIVE */
  @media screen and (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr; /* Stack vertically */
      gap: 40px;
    }
  }
{%- endstyle -%}

<footer class="footer-wrapper">
  <div class="footer-container">
    
    <div class="footer-grid">
      
      {%- comment -%} COLUMN 1: BRAND & SOCIALS {%- endcomment -%}
      <div class="footer-col-brand">
        <h4 class="footer-heading">{{ section.settings.brand_title }}</h4>
        <p class="footer-text">{{ section.settings.brand_text }}</p>
        
        <div class="footer-socials">
          <a href="#" aria-label="Instagram">
            <svg class="social-icon" viewBox="0 0 24 24"><path d="M7.8,2H16.2C19.4,2 22,4.6 22,7.8V16.2A5.8,5.8 0 0,1 16.2,22H7.8C4.6,22 2,19.4 2,16.2V7.8A5.8,5.8 0 0,1 7.8,2M7.6,4A3.6,3.6 0 0,0 4,7.6V16.4C4,18.39 5.61,20 7.6,20H16.4A3.6,3.6 0 0,0 20,16.4V7.6C20,5.61 18.39,4 16.4,4H7.6M17.25,5.5A1.25,1.25 0 0,1 18.5,6.75A1.25,1.25 0 0,1 17.25,8A1.25,1.25 0 0,1 16,6.75A1.25,1.25 0 0,1 17.25,5.5M12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9Z" /></svg>
          </a>
          <a href="#" aria-label="Facebook">
            <svg class="social-icon" viewBox="0 0 24 24"><path d="M12 2.04C6.5 2.04 2 6.53 2 12.06C2 17.06 5.66 21.21 10.44 21.96V14.96H7.9V12.06H10.44V9.85C10.44 7.34 11.93 5.96 14.15 5.96C15.21 5.96 16.12 6.04 16.12 6.04V8.51H15.01C13.77 8.51 13.38 9.28 13.38 10.07V12.06H16.15L15.71 14.96H13.38V21.96C18.16 21.21 21.82 17.06 21.82 12.06C21.82 6.53 17.32 2.04 12 2.04Z" /></svg>
          </a>
          <a href="#" aria-label="Twitter">
            <svg class="social-icon" viewBox="0 0 24 24"><path d="M22.46,6C21.69,6.35 20.86,6.58 20,6.69C20.88,6.16 21.56,5.32 21.88,4.31C21.05,4.81 20.13,5.16 19.16,5.36C18.37,4.5 17.26,4 16,4C13.65,4 11.73,5.92 11.73,8.29C11.73,8.63 11.77,8.96 11.84,9.27C8.28,9.09 5.11,7.38 3,4.79C2.63,5.42 2.42,6.16 2.42,6.94C2.42,8.43 3.17,9.75 4.33,10.5C3.62,10.5 2.96,10.3 2.38,10C2.38,10 2.38,10.03 2.38,10.05C2.38,12.13 3.86,13.86 5.82,14.24C5.46,14.34 5.08,14.39 4.69,14.39C4.42,14.39 4.15,14.36 3.89,14.31C4.43,16 6,17.26 7.89,17.29C6.43,18.45 4.58,19.13 2.56,19.13C2.22,19.13 1.88,19.11 1.54,19.07C3.44,20.29 5.7,21 8.12,21C16,21 20.33,14.46 20.33,8.79C20.33,8.6 20.33,8.42 20.32,8.23C21.16,7.63 21.88,6.87 22.46,6Z" /></svg>
          </a>
        </div>
      </div>

      {%- comment -%} MENU COLUMNS {%- endcomment -%}
      {%- for block in section.blocks -%}
        <div class="footer-col-menu">
          <h4 class="footer-heading">{{ block.settings.title }}</h4>
          <ul class="footer-links">
            {%- for link in block.settings.menu.links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endfor -%}

    </div>

    <div class="footer-bottom">
      &copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All rights reserved.
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Custom Footer",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#555555"
    },
    {
      "type": "header",
      "content": "Brand Column"
    },
    {
      "type": "text",
      "id": "brand_title",
      "label": "Brand Title",
      "default": "ATELIER"
    },
    {
      "type": "textarea",
      "id": "brand_text",
      "label": "Brand Description",
      "default": "Premium contemporary fashion for the modern wardrobe. Crafted with care, designed with purpose."
    }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menu Column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column Heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Select Menu",
          "default": "footer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Footer",
      "blocks": [
        { "type": "menu_column", "settings": { "title": "Shop" } },
        { "type": "menu_column", "settings": { "title": "Company" } },
        { "type": "menu_column", "settings": { "title": "Help" } }
      ]
    }
  ]
}
{% endschema %}