{%- style -%}
  .values-section { padding: 0 40px 100px 40px; max-width: 1200px; margin: 0 auto; border-top: 1px solid #eee; padding-top: 60px; }
  .values-title { font-size: 32px; font-weight: 600; margin-bottom: 40px; color: #000; }
  .values-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 60px; }
  .value-item h3 { font-size: 20px; font-weight: 600; margin-bottom: 12px; color: #000; }
  .value-item p { font-size: 15px; line-height: 1.6; color: #555; }
  @media screen and (max-width: 900px) { .values-grid { grid-template-columns: 1fr; gap: 40px; } .values-section { padding: 0 20px 80px 20px; } }
{%- endstyle -%}

<div class="values-section">
  {% if section.settings.title != blank %}<h2 class="values-title">{{ section.settings.title }}</h2>{% endif %}
  <div class="values-grid">
    {%- for block in section.blocks -%}
      <div class="value-item">
        <h3>{{ block.settings.heading }}</h3>
        <p>{{ block.settings.text }}</p>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "About - Values",
  "settings": [ { "type": "text", "id": "title", "label": "Section Heading", "default": "Our Values" } ],
  "blocks": [
    {
      "type": "value",
      "name": "Value Column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Quality" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Description of value." }
      ]
    }
  ],
  "presets": [
    {
      "name": "About - Values",
      "blocks": [
        { "type": "value", "settings": { "heading": "Quality", "text": "We use only the finest materials..." } },
        { "type": "value", "settings": { "heading": "Sustainability", "text": "We're committed to responsible production..." } },
        { "type": "value", "settings": { "heading": "Timelessness", "text": "Our designs are created to last..." } }
      ]
    }
  ]
}
{% endschema %}