{% comment %}
  PIXEL PERFECT - MAIN CONTACT
  1. Layout: CSS Grid (Left Column: Info + FAQ | Right Column: Form).
  2. Icons: Embedded SVGs for Email, Phone, Map, Clock.
  3. Form: Fully functional Shopify contact form.
{% endcomment %}

{%- style -%}
  .contact-main-section {
    padding: 60px 40px 100px 40px;
    background-color: #FFFFFF;
  }

  .contact-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    /* 1fr for Info, 1.5fr for Form to give the form more space */
    grid-template-columns: 1fr 1.5fr; 
    gap: 80px;
  }

  /* --- LEFT COLUMN: INFO & FAQ --- */
  .contact-left-col {
    display: flex;
    flex-direction: column;
    gap: 60px; /* Space between Info and FAQ */
  }

  /* INFO BLOCK */
  .info-group h2, .faq-group h2, .form-group h2 {
    font-size: 24px;
    font-weight: 600;
    margin-bottom: 32px;
    color: #111820;
    letter-spacing: -0.01em;
  }

  .info-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .info-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .icon-box {
    width: 48px;
    height: 48px;
    background-color: #F7F7F7; /* Light grey box */
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .icon-box svg {
    width: 20px;
    height: 20px;
    color: #333;
  }

  .info-content h3 {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 4px 0;
    color: #000;
  }

  .info-content p {
    font-size: 15px;
    color: #555;
    margin: 0;
    line-height: 1.5;
  }

  /* FAQ BLOCK */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .faq-item h3 {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 8px 0;
    color: #000;
  }

  .faq-item p {
    font-size: 15px;
    line-height: 1.6;
    color: #555;
    margin: 0;
  }

  /* --- RIGHT COLUMN: FORM --- */
  .contact-form-wrapper {
    background: #FFFFFF;
  }

  .form-row {
    margin-bottom: 20px;
  }

  .form-label {
    display: block;
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 8px;
    color: #333;
  }

  .form-input, .form-select, .form-textarea {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid #E5E5E5;
    border-radius: 4px;
    font-size: 15px;
    color: #333;
    outline: none;
    transition: border-color 0.2s;
    background-color: #FFFFFF;
  }

  .form-input:focus, .form-select:focus, .form-textarea:focus {
    border-color: #000;
  }

  .form-textarea {
    min-height: 180px;
    resize: vertical;
  }

  .submit-btn {
    width: 100%;
    padding: 16px;
    background-color: #111820; /* Dark button */
    color: #FFFFFF;
    font-size: 16px;
    font-weight: 600;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    transition: opacity 0.3s;
  }

  .submit-btn:hover {
    opacity: 0.9;
  }

  /* MOBILE RESPONSIVE */
  @media screen and (max-width: 900px) {
    .contact-wrapper {
      grid-template-columns: 1fr; /* Stack vertically */
      gap: 60px;
    }
    .contact-main-section {
      padding: 40px 20px 80px 20px;
    }
  }
{%- endstyle -%}

<div class="contact-main-section">
  <div class="contact-wrapper">
    
    {%- comment -%} LEFT COL: INFO & FAQ {%- endcomment -%}
    <div class="contact-left-col">
      
      <div class="info-group">
        <h2>Contact Information</h2>
        <div class="info-list">
          <div class="info-item">
            <div class="icon-box">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </div>
            <div class="info-content">
              <h3>Email</h3>
              <p>{{ section.settings.email }}</p>
            </div>
          </div>

          <div class="info-item">
            <div class="icon-box">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            </div>
            <div class="info-content">
              <h3>Phone</h3>
              <p>{{ section.settings.phone }}</p>
            </div>
          </div>

          <div class="info-item">
            <div class="icon-box">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </div>
            <div class="info-content">
              <h3>Address</h3>
              <p>{{ section.settings.address | newline_to_br }}</p>
            </div>
          </div>

          <div class="info-item">
            <div class="icon-box">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            </div>
            <div class="info-content">
              <h3>Business Hours</h3>
              <p>{{ section.settings.hours | newline_to_br }}</p>
            </div>
          </div>
        </div>
      </div>

      <div class="faq-group">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-list">
          {%- for block in section.blocks -%}
            <div class="faq-item">
              <h3>{{ block.settings.question }}</h3>
              <p>{{ block.settings.answer }}</p>
            </div>
          {%- endfor -%}
        </div>
      </div>

    </div>

    {%- comment -%} RIGHT COL: FORM {%- endcomment -%}
    <div class="contact-right-col">
      <div class="form-group">
        <h2>Send Us a Message</h2>
        {%- form 'contact' -%}
          {%- if form.posted_successfully? -%}
            <p style="color: green; margin-bottom: 20px;">Thanks for contacting us! We'll get back to you shortly.</p>
          {%- endif -%}
          
          <div class="form-row">
            <label class="form-label" for="ContactFormName">Name</label>
            <input class="form-input" type="text" id="ContactFormName" name="contact[name]" placeholder="" required>
          </div>

          <div class="form-row">
            <label class="form-label" for="ContactFormEmail">Email</label>
            <input class="form-input" type="email" id="ContactFormEmail" name="contact[email]" placeholder="" required>
          </div>

          <div class="form-row">
            <label class="form-label" for="ContactFormSubject">Subject</label>
            <select class="form-select" id="ContactFormSubject" name="contact[subject]">
              <option>General Inquiry</option>
              <option>Order Status</option>
              <option>Returns & Exchanges</option>
              <option>Product Information</option>
            </select>
          </div>

          <div class="form-row">
            <label class="form-label" for="ContactFormMessage">Message</label>
            <textarea class="form-textarea" id="ContactFormMessage" name="contact[body]" placeholder="" required></textarea>
          </div>

          <button type="submit" class="submit-btn">Send Message</button>
        {%- endform -%}
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Main Contact Section",
  "settings": [
    { "type": "text", "id": "email", "label": "Email", "default": "hello@atelier.com" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "+1 (234) 567-890" },
    { "type": "textarea", "id": "address", "label": "Address", "default": "123 Fashion Avenue\nNew York, NY 10001\nUnited States" },
    { "type": "textarea", "id": "hours", "label": "Business Hours", "default": "Monday - Friday: 9:00 AM - 6:00 PM EST\nSaturday: 10:00 AM - 4:00 PM EST\nSunday: Closed" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "What is your return policy?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "We offer free returns within 30 days of purchase." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Main Contact Section",
      "blocks": [
        { "type": "faq", "settings": { "question": "What is your return policy?", "answer": "We offer free returns within 30 days of purchase for unworn items with original tags attached." } },
        { "type": "faq", "settings": { "question": "How long does shipping take?", "answer": "Standard shipping takes 5-7 business days. Express shipping is available for 2-3 business days delivery." } },
        { "type": "faq", "settings": { "question": "Do you ship internationally?", "answer": "Yes, we ship to over 50 countries worldwide. International shipping times and costs vary by location." } }
      ]
    }
  ]
}
{% endschema %}