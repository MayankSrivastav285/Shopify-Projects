        "review_category_9pFjqB": {
          "type": "review_category",
          "settings": {
            "category_name": "Cami",
            "r1_name": "Maria S.",
            "r1_text": "The material is fantastic. Smooth and thick enough without being hot. It softens my curves and pulls everything in without cutting off circulation or being oppressive. Bonus: there's also some gentle compression in the bust, so I don't have to wear a bra with it! I've already ordered 2 more.",
            "r2_name": "Kate B.",
            "r2_text": "It smooths out the extra skin on my stomach and adds support to my chest and really accentuates my curves. I've been wearing it for four hours, including forty-five minutes of yoga and aerobics, and it's stayed in place the entire time.",
            "r3_name": "Jessica H.",
            "r3_text": "I LOVE these camis!! I've worn them multiple times, and I even ran in one and was shocked with the support I had. I recommended them to all of my friends, and I will definitely be purchasing more in a variety of other colors."
          }
        },
        "review_category_PbN8mC": {
          "type": "review_category",
          "settings": {
            "category_name": "Shaper Shorts",
            "r1_name": "Monika M.",
            "r1_text": "If you want to be shaped and held in place all day, this is your new best friend.",
            "r2_name": "Sheretta C.",
            "r2_text": "I absolutely love this shaper. I have 4 kids and my youngest is 2, and this shaper gives me life. I recommend it to anyone with a belly they wanna smooth out.",
            "r3_name": "Catherine L.",
            "r3_text": "I'll tell my friends that using this shaper short will boost their confidence! And they will look even more fabulous and sexy!!!"
          }
        },
        "review_category_BGiGBC": {
          "type": "review_category",
          "settings": {
            "category_name": "Shaping Leggings",
            "r1_name": "Sarah",
            "r1_text": "I am 5'5\" and 153 pounds, and these leggings make me look 20 pounds lighter than I am. I highly recommend these. They do not roll down, and they feel like an extra skin! I can hardly even tell they're there!",
