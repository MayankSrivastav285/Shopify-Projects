      </a>
      
      <a href="{{ routes.account_login_url }}" class="sm-icon-link" aria-label="Account">
        {% if section.settings.account_icon != blank %}
          <img src="{{ section.settings.account_icon | image_url: width: 50 }}" class="sm-icon-img" alt="Account">
