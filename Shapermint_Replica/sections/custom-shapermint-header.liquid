        <button class="sm-icon-link" aria-label="Help">
          {% if section.settings.help_icon != blank %}
            <img src="{{ section.settings.help_icon | image_url: width: 50 }}" class="sm-icon-img" alt="Help">
          {% else %}
            <svg class="sm-icon-svg" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
              <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
          {% endif %}
        </button>
        <div class="sm-dropdown-box" style="right:-10px;">
          <a href="/pages/help" class="dropdown-item">Help Center</a>
          <a href="/pages/track" class="dropdown-item">Track Order</a>
        </div>
      </div>
      
      <a href="{{ routes.cart_url }}" class="sm-icon-link" style="margin-left:5px;" aria-label="Cart">
        {% if section.settings.cart_icon != blank %}
          <img src="{{ section.settings.cart_icon | image_url: width: 50 }}" class="sm-icon-img" alt="Cart">
        {% else %}
          <svg class="sm-icon-svg" viewBox="0 0 24 24">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <path d="M16 10a4 4 0 0 1-8 0"></path>
          </svg>
        {% endif %}
        {% if cart.item_count > 0 %}
          <span style="position:absolute; top:-6px; right:-6px; background:#f7a08b; color:white; font-size:10px; font-weight:700; width:17px; height:17px; border-radius:50%; display:flex; align-items:center; justify-content:center; border:2px solid white;">
