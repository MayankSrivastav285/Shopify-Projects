<script>

  document.addEventListener('DOMContentLoaded', function () {

  /* ===== MEGA MENU IMAGE SWAP ON HOVER ===== */

  document.querySelectorAll('.js-mega-panel').forEach(panel => {
    const mainImg = panel.querySelector('.sm-mega-img');
    if (!mainImg) return;

    const defaultSrc = mainImg.src;

    panel.querySelectorAll('.mega-hover-link').forEach(link => {
      const hoverImg = link.getAttribute('data-img');

      // Only if image exists
      if (!hoverImg) return;

      link.addEventListener('mouseenter', () => {
        mainImg.style.opacity = '0';
        setTimeout(() => {
          mainImg.src = hoverImg;
          mainImg.style.opacity = '1';
        }, 150);
      });

      // Reset back to promo image
      link.addEventListener('mouseleave', () => {
        mainImg.style.opacity = '0';
        setTimeout(() => {
          mainImg.src = defaultSrc;
          mainImg.style.opacity = '1';
        }, 150);
      });
    });
  });

});
  document.addEventListener('DOMContentLoaded', function() {
/* ===== DESKTOP MEGA MENU (STABLE) ===== */

const headerSection = document.getElementById('mainHeader');
const megaTriggers = document.querySelectorAll('.js-mega-trigger');
const allPanels = document.querySelectorAll('.js-mega-panel');
const menuItems = document.querySelectorAll('.sm-menu-item');

function closeAll() {
  allPanels.forEach(p => p.classList.remove('is-active'));
  megaTriggers.forEach(t => t.classList.remove('is-active'));
  menuItems.forEach(i => i.classList.remove('is-hovered'));
}

// Hover underline (NORMAL menu items only)
menuItems.forEach(item => {
  item.addEventListener('mouseenter', () => {
    // 🔑 FULL RESET: no underline survives
    menuItems.forEach(i => {
      i.classList.remove('is-hovered');
      i.classList.remove('is-active');
    });

    // Apply underline ONLY for non-mega items
    if (!item.classList.contains('js-mega-trigger')) {
      item.classList.add('is-hovered');
    }
  });
});


// Mega open (single underline GUARANTEED)
megaTriggers.forEach(trigger => {
  trigger.addEventListener('mouseenter', () => {
    const targetId = trigger.dataset.target;
    const targetPanel = document.getElementById(targetId);

    // 🔑 HARD RESET: remove ALL underline states
    menuItems.forEach(i => {
      i.classList.remove('is-hovered');
      i.classList.remove('is-active');
    });
    allPanels.forEach(p => p.classList.remove('is-active'));

    // Activate current mega
    if (targetPanel) {
      trigger.classList.add('is-active'); // ONLY source of underline
      targetPanel.classList.add('is-active');
    }
  });
});



// Close when leaving header entirely
headerSection.addEventListener('mouseleave', closeAll);

    window.changeCountry = function(flagUrl, currencyCode) {
      const flagEl = document.getElementById('selectedFlag');
      const currencyEl = document.getElementById('selectedCurrency');
      if(flagEl) flagEl.src = flagUrl;
      if(currencyEl) currencyEl.textContent = '| ' + currencyCode;
    };
    
    /* ===== MOBILE SLIDING MENU ===== */
    const mobToggle = document.getElementById('mobToggle');
    const mobileClose = document.getElementById('mobileClose');
    const mobileOverlay = document.getElementById('mobileOverlay');
    const mobileDrawer = document.getElementById('mobileDrawer');
    const mainMenuView = document.getElementById('mainMenuView');
    
    function openMobileMenu() {
      mobileOverlay.classList.add('is-active');
      mobileDrawer.classList.add('is-active');
      document.body.classList.add('mobile-menu-open');
    }
    
    function closeMobileMenu() {
      mobileOverlay.classList.remove('is-active');
      mobileDrawer.classList.remove('is-active');
      document.body.classList.remove('mobile-menu-open');
      
      setTimeout(() => {
        document.querySelectorAll('.sm-mobile-menu-view').forEach(view => {
          view.classList.remove('active', 'slide-out-left', 'slide-in-right');
        });
        mainMenuView.classList.add('active');
      }, 400);
    }
    
    if(mobToggle) mobToggle.addEventListener('click', openMobileMenu);
    if(mobileClose) mobileClose.addEventListener('click', closeMobileMenu);
    if(mobileOverlay) mobileOverlay.addEventListener('click', closeMobileMenu);
    
    document.addEventListener('keydown', function(e) {
      if(e.key === 'Escape') closeMobileMenu();
    });
    
    // Open Submenu
    document.querySelectorAll('[data-open-submenu]').forEach(trigger => {
      trigger.addEventListener('click', function() {
        const submenuId = this.getAttribute('data-open-submenu');
        const submenuView = document.getElementById('submenu-' + submenuId);
        
        if(submenuView) {
          mainMenuView.classList.remove('active');
          mainMenuView.classList.add('slide-out-left');
          
          submenuView.classList.remove('slide-in-right');
          submenuView.classList.add('active');
        }
      });
    });
    
    // Back to Main Menu
    document.querySelectorAll('[data-back-to-main]').forEach(backBtn => {
      backBtn.addEventListener('click', function() {
        const submenuView = this.closest('.sm-mobile-menu-view');
        
        submenuView.classList.remove('active');
        submenuView.classList.add('slide-in-right');
        
        mainMenuView.classList.remove('slide-out-left');
        mainMenuView.classList.add('active');
      });
    });
    
    // Close menu on link click
    document.querySelectorAll('.sm-mobile-submenu-link').forEach(link => {
      link.addEventListener('click', closeMobileMenu);
    });
  });
</script>

