          </button>
          <button class="dropdown-item" onclick="changeCountry('https://upload.wikimedia.org/wikipedia/en/a/ae/Flag_of_the_United_Kingdom.svg', 'GBP')">
            <img src="https://upload.wikimedia.org/wikipedia/en/a/ae/Flag_of_the_United_Kingdom.svg" class="flag-round" alt="UK Flag"> UK
          </button>
        </div>
      </div>
      
      <a href="{{ routes.search_url }}" class="sm-icon-link" aria-label="Search">
        {% if section.settings.search_icon != blank %}
          <img src="{{ section.settings.search_icon | image_url: width: 50 }}" class="sm-icon-img" alt="Search">
        {% else %}
          <svg class="sm-icon-svg" viewBox="0 0 24 24">
