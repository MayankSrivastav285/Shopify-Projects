              <span class="sm-mobile-submenu-group-title">{{ child.title }}</span>
              <div class="sm-mobile-submenu-items">
                {% for grandchild in child.links %}
                  {% comment %} Check for submenu image {% endcomment %}
                  {% assign submenu_image = nil %}
                  {% assign grandchild_handle = grandchild.title | handle %}
                  
                  {% for block in section.blocks %}
                    {% if block.type == 'mobile_submenu_image' %}
                      {% assign trigger_parent = block.settings.parent_menu_name | handle %}
                      {% assign trigger_item = block.settings.submenu_item_name | handle %}
                      {% assign link_handle_check = link.title | handle %}
                      
                      {% if trigger_parent == link_handle_check and trigger_item == grandchild_handle %}
                        {% assign submenu_image = block.settings.submenu_image %}
                      {% endif %}
                    {% endif %}
                  {% endfor %}
                  
                  <div class="sm-mobile-submenu-item">
