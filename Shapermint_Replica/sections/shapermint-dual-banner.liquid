{% comment %}
  SHAPERMINT REPLICA: DUAL BANNER V6 (ACTUAL PHOTO SIZE + WIDER GAP)
  - IMAGES: 'Height: Auto' allows the photos to show their full, natural landscape shape (No cropping).
  - GAP: Increased column gap to 60px.
  - TOP PADDING: Reduced to 0px.
  - TEXT SPACING: Increased margin below image to 25px.
{% endcomment %}

<style>
  .sm-dual-section {
    /* FIX: Top padding 0px to minimize gap to previous section's button */
    padding: 0 50px 60px; 
    max-width: 1200px;
    margin: 0 auto;
    font-family: 'Montserrat', sans-serif;
  }

  .sm-dual-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    /* FIX: Gap increased to 60px */
    gap: 60px; 
    align-items: start;
  }

  /* --- CARD STYLING --- */
  .sm-promo-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    color: inherit;
  }

  .sm-promo-img-wrap {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    /* FIX: Gap below image increased by ~5px */
    margin-bottom: 25px;
    background: #f4f4f4;
    
    /* FIX: Removed 'aspect-ratio'. This lets the image define the height naturally (Actual Size) */
    display: block;
    line-height: 0; 
  }

  .sm-promo-img {
    width: 100%;
    /* FIX: Height Auto ensures the full photo is shown (Landscape) without cropping */
    height: auto;
    display: block;
    transition: transform 0.3s ease;
  }

  /* Zoom effect on hover */
  .sm-promo-card:hover .sm-promo-img {
    transform: scale(1.03);
  }

  /* --- TYPOGRAPHY --- */
  .sm-promo-title {
    font-family: 'Poppins', sans-serif;
    font-size: 28px;
    font-weight: 800;
    color: #000;
    margin: 0 0 12px 0;
    line-height: 1.2;
  }

  .sm-promo-desc {
    font-size: 15px;
    color: #333;
    line-height: 1.6;
    margin: 0 0 24px 0;
    max-width: 400px;
  }

  /* --- BUTTON (OUTLINE STYLE) --- */
  .sm-promo-btn {
    display: inline-block;
    background: transparent;
    border: 1px solid #000;
    color: #000;
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    padding: 10px 32px;
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.2s ease;
    letter-spacing: 0.5px;
  }

  .sm-promo-btn:hover {
    background: #000;
    color: #fff;
  }

  /* --- RESPONSIVE --- */
  @media (max-width: 800px) {
    .sm-dual-grid {
      grid-template-columns: 1fr; /* Stack vertically on mobile */
      gap: 50px;
    }
    .sm-dual-section {
      padding: 30px 20px 50px;
    }
  }
</style>

<div class="sm-dual-section">
  <div class="sm-dual-grid">
    
    <div class="sm-promo-card">
      <a href="{{ section.settings.left_link }}" class="sm-promo-img-wrap">
        {% if section.settings.left_image != blank %}
          <img src="{{ section.settings.left_image | image_url: width: 1000 }}" loading="lazy" class="sm-promo-img" alt="{{ section.settings.left_title }}">
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'sm-promo-img' }}
        {% endif %}
      </a>
      
      <h3 class="sm-promo-title">{{ section.settings.left_title }}</h3>
      <div class="sm-promo-desc">{{ section.settings.left_desc }}</div>
      
      {% if section.settings.left_btn_text != blank %}
        <a href="{{ section.settings.left_link }}" class="sm-promo-btn">
          {{ section.settings.left_btn_text }}
        </a>
      {% endif %}
    </div>

    <div class="sm-promo-card">
      <a href="{{ section.settings.right_link }}" class="sm-promo-img-wrap">
        {% if section.settings.right_image != blank %}
          <img src="{{ section.settings.right_image | image_url: width: 1000 }}" loading="lazy" class="sm-promo-img" alt="{{ section.settings.right_title }}">
        {% else %}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'sm-promo-img' }}
        {% endif %}
      </a>
      
      <h3 class="sm-promo-title">{{ section.settings.right_title }}</h3>
      <div class="sm-promo-desc">{{ section.settings.right_desc }}</div>
      
      {% if section.settings.right_btn_text != blank %}
        <a href="{{ section.settings.right_link }}" class="sm-promo-btn">
          {{ section.settings.right_btn_text }}
        </a>
      {% endif %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Dual Promo Banner",
  "settings": [
    {
      "type": "header",
      "content": "Left Promo"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "left_title",
      "label": "Heading",
      "default": "Get the scoop"
    },
    {
      "type": "textarea",
      "id": "left_desc",
      "label": "Description",
      "default": "From perfect fit guides & new arrivals, to style inspo & wellness, we have you covered."
    },
    {
      "type": "text",
      "id": "left_btn_text",
      "label": "Button Label",
      "default": "READ THE BLOG"
    },
    {
      "type": "url",
      "id": "left_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Right Promo"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "right_title",
      "label": "Heading",
      "default": "New Arrivals"
    },
    {
      "type": "textarea",
      "id": "right_desc",
      "label": "Description",
      "default": "Brand new confidence-boosting styles just dropped! Discover your faves today."
    },
    {
      "type": "text",
      "id": "right_btn_text",
      "label": "Button Label",
      "default": "SHOP NEW ARRIVALS"
    },
    {
      "type": "url",
      "id": "right_link",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Dual Promo Banner"
    }
  ]
}
{% endschema %}