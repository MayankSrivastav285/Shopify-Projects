  let siyData = fallbackModelData;
  try { const themeData = JSON.parse(document.getElementById('ModelData').textContent); if(Object.keys(themeData).length > 0) siyData = { ...fallbackModelData, ...themeData }; } catch(e) {}
  let currentSIYSize = '';

  function openFitFlow() {
  document.getElementById('FitGuideModal').classList.add('open');
  goToStep(1);
}

function closeFitFlow() {
  document.getElementById('FitGuideModal').classList.remove('open');
}

function goToStep(step) {
  document.querySelectorAll('.fit-step')
    .forEach(s => s.classList.remove('active'));
  document.getElementById(`fit-step-${step}`)
    .classList.add('active');
}

function toggleCalculator() {
  const sec = document.getElementById('CalculatorSection');
  const icon = document.getElementById('toggleIcon');
  sec.classList.toggle('hidden');
  icon.textContent = sec.classList.contains('hidden') ? '+' : '−';
}


function calculateBraSize() {
  const under = parseInt(document.getElementById('Underbust').value);
  const bust = parseInt(document.getElementById('FullBust').value);

  if (!under || !bust) return alert('Please enter measurements');

  const band = Math.round(under / 2) * 2;
  const diff = bust - under;

  let cup = 'A';
  if (diff >= 4) cup = 'D';
  if (diff >= 5) cup = 'DD/E';
  if (diff >= 6) cup = 'DDD/F';

  const map = { A:'S', B:'S', C:'M', D:'L', 'DD/E':'L', 'DDD/F':'XL' };

  document.getElementById('BraResult').innerText = `${band}${cup}`;
  document.getElementById('FinalSize').innerText = map[cup] || 'M';

  goToStep(3);
}

function applySize() {
  const size = document.getElementById('FinalSize').innerText;
  const radio = document.querySelector(`input[name="options[Size]"][value="${size}"]`);
  if (radio) {
    radio.checked = true;
    updateVariant(radio);
  }
  closeFitFlow();
}

