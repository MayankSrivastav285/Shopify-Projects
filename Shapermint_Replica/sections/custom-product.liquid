    if(mobStage) {
      mobStage.addEventListener('scroll', () => {
        const index = Math.round(mobStage.scrollLeft / mobStage.offsetWidth);
        dots.forEach((d, i) => d.classList.toggle('active', i === index));
      });
    }

    // Desktop Zoom
    const stage = document.getElementById('MainStage');
    const deskImg = document.getElementById('MainImgDesktop');
    if(stage && deskImg) {
      stage.addEventListener('mousemove', (e) => {
        if (window.innerWidth <= 900) return; 
        const rect = stage.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        deskImg.style.transformOrigin = `${x}% ${y}%`;
        deskImg.style.transform = 'scale(2)';
      });
      stage.addEventListener('mouseleave', () => {
        deskImg.style.transform = 'scale(1)';
        setTimeout(() => { deskImg.style.transformOrigin = 'center center'; }, 100);
      });
    }
  });
  

  function updateVariant(input) {
    const nameMatch = input.name.match(/\[(.*?)\]/);
    if(nameMatch) document.getElementById(`Label-${nameMatch[1]}`).textContent = input.value;
    
    const container = input.closest('.sm-colors') || input.closest('.sm-sizes');
    container.querySelectorAll('.sm-color-ball, .sm-size-opt').forEach(d => d.classList.remove('active'));
    input.nextElementSibling.classList.add('active');

   

    if(input.name.includes('Size')) updateFitsText(input.value);
    
    const form = document.getElementById('product-form');

/* Collect selected options by NAME (safe) */
const selectedOptions = {};
form.querySelectorAll('input[type="radio"]:checked').forEach(input => {
  const match = input.name.match(/\[(.*?)\]/);
  if (match) {
    selectedOptions[match[1]] = input.value;
  }
});

/* Find correct variant (order-independent) */
const variant = productVariants.find(v => {
  return Object.entries(selectedOptions).every(([name, value]) => {
    const optionIndex = PRODUCT_OPTION_NAMES.indexOf(name);
if (optionIndex === -1) return false;
return v.options[optionIndex] === value;

  });
});

    
    if (variant) {
  // set variant id
  form.querySelector('input[name="id"]').value = variant.id;

  // update price
  const parts = (variant.price / 100).toFixed(2).split('.');
  document.getElementById('PriceInt').textContent = parts[0];
  document.getElementById('PriceDec').textContent = parts[1];

  // 🔥 THIS IS THE KEY FIX: update main image from variant
  if (variant.featured_image) {
    document.getElementById('MainImgDesktop').src =
      variant.featured_image.src;
  }
}

  }

  function updateFakeColor(input) {
    document.getElementById('Label-Color').textContent = input.value;
    const container = input.closest('.sm-colors') || input.closest('.sm-sizes');
if (container) {
  container.querySelectorAll('.sm-color-ball, .sm-size-opt')
    .forEach(d => d.classList.remove('active'));
}
if (input.nextElementSibling) {
  input.nextElementSibling.classList.add('active');
}

    filterGallery(input.value);
  }

  function filterGallery(colorName) {
    const thumbs = document.querySelectorAll('.sm-thumb');
    let matchCount = 0;
    thumbs.forEach(t => {
      const alt = t.getAttribute('data-alt');
      if(!alt || alt.toLowerCase().includes(colorName.toLowerCase())) { t.classList.remove('filtered-out'); matchCount++; }
      else t.classList.add('filtered-out');
    });
    if(matchCount === 0) thumbs.forEach(t => t.classList.remove('filtered-out'));
    const first = document.querySelector('.sm-thumb:not(.filtered-out)');
    if(first) first.click();
  }

  function updateFitsText(size) {
    const el = document.getElementById('FitsText');
    const data = siyData[size];
    const defaultFits = { 'S': '30B-32B', 'M': '32C-34C', 'L': '34D-36D', 'XL': '36DD-40C', '2XL': '38DD-42D', '3XL': '42DD-44D', '4XL': '44DD-46D' };
    const text = (data && data.fit_text) ? data.fit_text : (defaultFits[size] || 'Select a size');
    el.innerHTML = `<strong>Fits sizes:</strong> ${text}`;
  }

  function openModal(id) { document.getElementById(id).classList.add('open'); if(id==='ModalSIY') setTimeout(initSIY, 50); }
  function closeModal(id) { document.getElementById(id).classList.remove('open'); }
  function swapImage(src, t) { document.getElementById('MainImgDesktop').src = src; document.querySelectorAll('.sm-thumb').forEach(x => x.classList.remove('active')); t.classList.add('active'); }
  function scrollGallery(dir) { const stage = document.getElementById('MobileStage'); stage.scrollBy({ left: stage.offsetWidth * dir, behavior: 'smooth' }); }
  function openLightbox() {
    const stage = document.getElementById('MobileStage');
    const index = Math.round(stage.scrollLeft / stage.offsetWidth);
    const images = stage.querySelectorAll('img');
    const lbModal = document.getElementById('LightboxModal');
    const lbImg = document.getElementById('LightboxImg');
    lbImg.src = images[index] ? images[index].src : images[0].src;
    lbModal.classList.add('open');
    lbImg.classList.remove('zoomed'); 
  }
  function closeLightbox(e) { if (e.target !== document.getElementById('LightboxImg')) document.getElementById('LightboxModal').classList.remove('open'); }
  document.getElementById('LightboxImg').addEventListener('click', function(e) { e.stopPropagation(); this.classList.toggle('zoomed'); });

  function initSIY() {
    const con = document.getElementById('SIY-Buttons'); con.innerHTML = '';
    const cur = document.querySelector('input[name="options[Size]"]:checked')?.value || 'S';
    Object.keys(siyData).forEach(s => {
      const btn = document.createElement('div');
      btn.className = `sm-size-opt ${s===cur?'active':''}`; btn.innerText = s;
      btn.onclick = () => updateSIY(s);
      con.appendChild(btn);
    });
    updateSIY(cur);
  }

  function updateSIY(size) {
    const data = siyData[size] || siyData['S'];
    currentSIYSize = size;
    const mainImg = document.getElementById('MainImgDesktop').src;
    const img = (data.image && data.image.length > 20) ? data.image : mainImg;
    document.getElementById('SIY-Img').src = img;
    document.getElementById('SIY-Desc').innerHTML = `<strong>${data.name}</strong> is ${data.height} and wears <strong>${size}</strong>.<br>${data.stats}`;
    document.getElementById('SIY-CTA').innerText = `SELECT SIZE ${size}`;
    document.querySelectorAll('#SIY-Buttons .sm-size-opt').forEach(b => {
      if(b.innerText === size) { b.style.backgroundColor = '#292929'; b.style.color = '#fff'; b.style.borderColor = '#292929'; }
      else { b.style.backgroundColor = '#fff'; b.style.color = '#292929'; b.style.borderColor = '#e0e0e0'; }
    });
  }

  function confirmSIY() {
    const r = document.querySelector(`input[name="options[Size]"][value="${currentSIYSize}"]`);
    if(r) { r.checked = true; updateVariant(r); closeModal('ModalSIY'); }
  }
</script>

