{% comment %}
  SHAPERMINT REPLICA: COLLECTION SUB-CATEGORIES V2
  - DIMENSIONS: Reduced container size slightly (126px x 166px) for a tighter look.
  - ALIGNMENT: 160px Padding preserved to align with Header.
  - LAYOUT: Horizontal row with scroll capability.
{% endcomment %}

<style>
  .sm-subcat-section {
    padding: 20px 0 40px;
    background-color: #ffffff;
    overflow: hidden;
  }

  /* --- CONTAINER --- */
  .sm-subcat-inner {
    max-width: 1600px;
    margin: 0 auto;
    
    /* ALIGNMENT: Matches Header V65 & Banner V12 */
    padding: 0 160px; 
  }

  /* --- LIST LAYOUT --- */
  .sm-subcat-list {
    display: flex;
    gap: 20px;
    
    /* Flex-wrap nowrap ensures they stay in a single row */
    flex-wrap: nowrap; 
    overflow-x: auto;
    
    padding-bottom: 20px; /* Hide scrollbar spacing */
    margin-bottom: -20px; 
    
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-behavior: smooth;
  }
  .sm-subcat-list::-webkit-scrollbar { display: none; }

  /* --- ITEM CARD --- */
  .sm-subcat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    
    /* FIX: Decreased slightly from 130px -> 126px */
    width: 126px; 
    flex-shrink: 0;
    cursor: pointer;
  }

  /* IMAGE (Vertical Portrait) */
  .sm-subcat-img-wrap {
    /* FIX: Tighter dimensions */
    width: 126px;
    height: 166px; 
    
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 10px;
    background-color: #f4f4f4;
    position: relative;
  }

  .sm-subcat-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .sm-subcat-item:hover .sm-subcat-img {
    transform: scale(1.05); /* Subtle zoom */
  }

  /* TEXT */
  .sm-subcat-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: #1f1f1f;
    text-align: center;
    line-height: 1.3;
  }

  /* --- RESPONSIVE --- */
  @media (max-width: 1200px) {
    .sm-subcat-inner { padding: 0 40px; }
  }

  @media (max-width: 768px) {
    .sm-subcat-section { padding: 20px 0; }
    .sm-subcat-inner { padding: 0 20px; }
    
    /* Mobile sizes */
    .sm-subcat-item { width: 100px; }
    .sm-subcat-img-wrap { width: 100px; height: 130px; }
    .sm-subcat-title { font-size: 12px; }
  }
</style>

<div class="sm-subcat-section">
  <div class="sm-subcat-inner">
    <div class="sm-subcat-list">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="sm-subcat-item">
          <div class="sm-subcat-img-wrap">
            {% if block.settings.image != blank %}
              <img 
                src="{{ block.settings.image | image_url: width: 400 }}" 
                alt="{{ block.settings.title }}" 
                class="sm-subcat-img" 
                loading="lazy"
              >
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'sm-subcat-img' }}
            {% endif %}
          </div>
          <span class="sm-subcat-title">{{ block.settings.title }}</span>
        </a>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection Sub-Categories",
  "settings": [],
  "blocks": [
    {
      "type": "category",
      "name": "Sub-Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image (Portrait)" },
        { "type": "text", "id": "title", "label": "Title", "default": "Wireless Bras" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Sub-Categories",
      "blocks": [
        { "type": "category", "settings": { "title": "Wireless Bras" } },
        { "type": "category", "settings": { "title": "T-shirt Bras" } },
        { "type": "category", "settings": { "title": "Bralettes" } },
        { "type": "category", "settings": { "title": "Strapless" } },
        { "type": "category", "settings": { "title": "Sports Bras" } },
        { "type": "category", "settings": { "title": "Full Coverage" } }
      ]
    }
  ]
}
{% endschema %}