{% comment %}
  SHAPERMINT REPLICA: PRESS LOGO BAR (SECTION 6)
  - STRUCTURE: Individual Image Blocks for each logo.
  - LAYOUT: Flexbox row, centered, auto-spacing.
  - STYLE: Minimalist "In The Press" header with light background.
{% endcomment %}

<style>
  .sm-press-section {
    padding: 60px 0;
    background-color: {{ section.settings.bg_color }};
    border-top: 1px solid #f0f0f0;
  }

  .sm-press-inner {
    max-width: 1200px; /* Narrower container for logos */
    margin: 0 auto;
    padding: 0 40px;
    text-align: center;
  }

  /* Header */
  .sm-press-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0 0 40px;
  }

  /* Logo Row */
  .sm-logo-row {
    display: flex;
    justify-content: space-between; /* Spreads logos evenly */
    align-items: center;
    flex-wrap: wrap;
    gap: 40px;
  }

  /* Individual Logo Item */
  .sm-logo-item {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    min-width: 120px; /* Ensures logos don't get too small on mobile */
  }

  .sm-logo-img {
    max-width: 100%;
    height: auto;
    max-height: 35px; /* Controls consistent height */
    object-fit: contain;
    filter: grayscale(100%); /* Optional: Makes colored logos black/grey */
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }
  
  .sm-logo-img:hover {
    opacity: 1;
    filter: grayscale(0%);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .sm-press-section { padding: 40px 0; }
    .sm-logo-row { gap: 30px; justify-content: center; } /* Center stack on mobile */
    .sm-logo-item { flex: 0 0 40%; } /* 2 logos per row on mobile */
    .sm-logo-img { max-height: 25px; }
  }
</style>

<div class="sm-press-section">
  <div class="sm-press-inner">
    
    {% if section.settings.heading != blank %}
      <h3 class="sm-press-title">{{ section.settings.heading }}</h3>
    {% endif %}

    <div class="sm-logo-row">
      {% for block in section.blocks %}
        <div class="sm-logo-item" {{ block.shopify_attributes }}>
          {% if block.settings.logo != blank %}
            <img src="{{ block.settings.logo | image_url: width: 400 }}" 
                 alt="{{ block.settings.logo.alt | default: 'Press Logo' }}" 
                 class="sm-logo-img" 
                 loading="lazy"
                 width="{{ block.settings.logo_width }}"
                 style="max-height: {{ block.settings.logo_height }}px;">
          {% else %}
            <div style="font-family:'Poppins'; font-weight:700; font-size:20px; color:#ccc;">LOGO {{ forloop.index }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Press Logo Bar",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "IN THE PRESS"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FAF9F6"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Press Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo Image"
        },
        {
          "type": "range",
          "id": "logo_height",
          "min": 20,
          "max": 80,
          "step": 2,
          "unit": "px",
          "label": "Max Logo Height",
          "default": 30
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Press Logo Bar",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}