{% comment %}
  SHAPERMINT REPLICA: MAIN FOOTER V2 (MOBILE GRID FIX)
  - DESKTOP: 3 Columns (Links | Links | Newsletter).
  - MOBILE: 2 Columns for Links (Side-by-Side) + Full Width Newsletter below.
{% endcomment %}

<style>
  .sm-main-footer {
    background-color: {{ section.settings.bg_color }};
    padding: 60px 20px 30px;
    font-family: 'Montserrat', sans-serif;
    color: #1F1F1F;
    border-top: 1px solid #E5E5E5; 
  }

  .sm-main-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* --- TOP GRID --- */
  .sm-footer-top {
    display: grid;
    /* Desktop: 3 Columns */
    grid-template-columns: 1fr 1fr 1.2fr; 
    gap: 40px;
    padding-bottom: 60px;
  }

  /* --- HEADINGS --- */
  .sm-footer-heading {
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 20px;
    color: #000;
  }

  /* --- LINKS LISTS --- */
  .sm-footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sm-footer-links li {
    margin-bottom: 10px;
  }

  .sm-footer-links a {
    text-decoration: none;
    color: #333;
    font-size: 13px; /* Slightly smaller for better fit */
    font-weight: 400; 
    transition: color 0.2s;
  }

  .sm-footer-links a:hover {
    color: #000;
    text-decoration: underline;
  }

  /* --- NEWSLETTER SECTION --- */
  .sm-newsletter-text {
    font-size: 14px;
    line-height: 1.5;
    margin-bottom: 20px;
    color: #333;
  }

  .sm-newsletter-form {
    display: flex;
    margin-bottom: 25px;
  }

  .sm-input {
    flex: 1;
    padding: 12px 15px;
    border: 1px solid #ccc;
    border-right: none;
    font-size: 14px;
    font-family: inherit;
    border-radius: 4px 0 0 4px;
    min-width: 0; /* Prevents overflow */
  }

  .sm-submit-btn {
    background-color: #1F1F1F;
    color: #fff;
    border: 1px solid #1F1F1F;
    padding: 0 20px;
    font-family: 'Poppins', sans-serif;
    font-weight: 700;
    font-size: 13px;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 0 4px 4px 0;
    transition: opacity 0.2s;
  }
  .sm-submit-btn:hover { opacity: 0.9; }

  /* --- SOCIAL ICONS --- */
  .sm-social-icons {
    display: flex;
    gap: 20px;
    margin-bottom: 30px;
    align-items: center;
  }

  .sm-social-icon svg {
    width: 20px;
    height: 20px;
    fill: #1F1F1F;
    transition: fill 0.2s;
  }
  .sm-social-icon:hover svg { fill: #555; }

  /* --- APP BUTTONS --- */
  .sm-app-section { margin-top: 20px; }
  
  .sm-app-heading {
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 15px;
    color: #000;
  }

  .sm-app-btns {
    display: flex;
    gap: 10px;
  }

  .sm-app-btn-img {
    height: 35px;
    width: auto;
    border-radius: 4px;
  }

  /* --- BOTTOM BAR --- */
  .sm-footer-bottom {
    border-top: 1px solid #E5E5E5;
    padding-top: 30px;
    text-align: center;
    font-size: 12px;
    color: #555;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }

  .sm-legal-links {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }

  .sm-legal-link {
    text-decoration: none;
    color: #555;
    transition: color 0.2s;
  }
  .sm-legal-link:hover { text-decoration: underline; color: #000; }

  .sm-divider { color: #ccc; }

  /* --- RESPONSIVE FIX --- */
  @media (max-width: 900px) {
    .sm-footer-top {
      /* FIX: 2 Columns on Mobile (Links side-by-side) */
      grid-template-columns: 1fr 1fr;
      gap: 30px 20px;
    }

    /* FIX: Make the 3rd column (Newsletter) span FULL width below links */
    .sm-footer-top > div:nth-child(3) {
      grid-column: 1 / -1; /* Span all columns */
      border-top: 1px solid #eee;
      padding-top: 30px;
      margin-top: 10px;
      text-align: center;
    }

    /* Center the elements in the bottom section */
    .sm-newsletter-form {
      max-width: 100%;
      margin: 0 auto 25px;
    }
    
    .sm-social-icons { justify-content: center; }
    .sm-app-btns { justify-content: center; }
    
    .sm-footer-bottom {
      flex-direction: column;
      gap: 15px;
    }
  }
</style>

<div class="sm-main-footer">
  <div class="sm-main-container">

    <div class="sm-footer-top">
      
      <div>
        <h4 class="sm-footer-heading">{{ section.settings.menu_1_title }}</h4>
        <ul class="sm-footer-links">
          {% for link in linklists[section.settings.menu_1].links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <div>
        <h4 class="sm-footer-heading">{{ section.settings.menu_2_title }}</h4>
        <ul class="sm-footer-links">
          {% for link in linklists[section.settings.menu_2].links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <div>
        <h4 class="sm-footer-heading">{{ section.settings.newsletter_title }}</h4>
        <p class="sm-newsletter-text">{{ section.settings.newsletter_desc }}</p>

        {% form 'customer', class: 'sm-newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input 
            type="email" 
            name="contact[email]" 
            class="sm-input" 
            placeholder="Enter your email" 
            required
          >
          <button type="submit" class="sm-submit-btn">SIGN UP</button>
        {% endform %}

        <div class="sm-social-icons">
          <a href="#" class="sm-social-icon"><svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg></a>
          <a href="#" class="sm-social-icon"><svg viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg></a>
          <a href="#" class="sm-social-icon"><svg viewBox="0 0 24 24"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg></a>
          <a href="#" class="sm-social-icon"><svg viewBox="0 0 24 24"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg></a>
          <a href="#" class="sm-social-icon"><svg viewBox="0 0 24 24"><path d="M12 0c-6.627 0-12 5.372-12 12 0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.65 0-5.789 2.738-5.789 5.57 0 1.103.425 2.286.953 2.929.105.128.12.242.09.436-.096.403-.311 1.261-.353 1.437-.056.239-.189.29-.438.175-1.635-.762-2.653-3.15-2.653-5.071 0-4.128 3.004-7.915 8.663-7.915 4.545 0 8.08 3.243 8.08 7.579 0 4.522-2.849 8.164-6.804 8.164-1.328 0-2.578-.691-3.006-1.508l-.818 3.116c-.294 1.135-1.092 2.557-1.625 3.425 1.226.378 2.525.586 3.873.586 6.627 0 12-5.373 12-12s-5.373-12-12-12z"/></svg></a>
        </div>

        <div class="sm-app-section">
          <h4 class="sm-app-heading">GET THE APP</h4>
          <div class="sm-app-btns">
            {% if section.settings.play_btn != blank %}
              <img src="{{ section.settings.play_btn | image_url: width: 300 }}" class="sm-app-btn-img" alt="Google Play">
            {% endif %}
            {% if section.settings.ios_btn != blank %}
              <img src="{{ section.settings.ios_btn | image_url: width: 300 }}" class="sm-app-btn-img" alt="App Store">
            {% endif %}
          </div>
        </div>

      </div>
    </div>

    <div class="sm-footer-bottom">
      <span>{{ section.settings.copyright }}</span>
      
      <div class="sm-legal-links">
        <span class="sm-divider">|</span>
        {% for link in linklists[section.settings.legal_menu].links %}
          <a href="{{ link.url }}" class="sm-legal-link">{{ link.title }}</a>
          {% unless forloop.last %}
            <span class="sm-divider">|</span>
          {% endunless %}
        {% endfor %}
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Main Footer",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F9F9F9"
    },
    {
      "type": "header",
      "content": "Menu Column 1 (Info)"
    },
    { "type": "text", "id": "menu_1_title", "label": "Heading", "default": "SHAPERMINT INFO" },
    { "type": "link_list", "id": "menu_1", "label": "Menu" },
    {
      "type": "header",
      "content": "Menu Column 2 (Care)"
    },
    { "type": "text", "id": "menu_2_title", "label": "Heading", "default": "CUSTOMER CARE" },
    { "type": "link_list", "id": "menu_2", "label": "Menu" },
    {
      "type": "header",
      "content": "Newsletter & Apps"
    },
    { "type": "text", "id": "newsletter_title", "label": "Newsletter Heading", "default": "Join Us & Get 10% OFF" },
    { "type": "textarea", "id": "newsletter_desc", "label": "Description", "default": "By signing up you agree to subscribe to our newsletter for first access to sales and offers." },
    { "type": "image_picker", "id": "play_btn", "label": "Google Play Button" },
    { "type": "image_picker", "id": "ios_btn", "label": "App Store Button" },
    {
      "type": "header",
      "content": "Bottom Bar"
    },
    { "type": "text", "id": "copyright", "label": "Copyright Text", "default": "© 2026 Shapermint. All rights reserved." },
    { "type": "link_list", "id": "legal_menu", "label": "Legal Links Menu" }
  ],
  "presets": [
    {
      "name": "Main Footer"
    }
  ]
}
{% endschema %}