{% comment %}
  SHAPERMINT REPLICA: BLOG POSTS GRID V2
  - SPACING UPDATE: Padding Top 0px, Padding Bottom 5px.
  - DESIGN: 3-Column Grid, Shadowed Cards, Rounded Corners.
  - ALIGNMENT: 160px Padding (Matches Main Grid).
{% endcomment %}

<style>
  .sm-blog-section {
    /* 🔥 SPACING FIX: Top 0, Bottom 5px */
    padding: 0 0 5px;
    background-color: #ffffff;
  }

  .sm-blog-inner {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 160px; /* Alignment Match */
  }

  /* --- HEADER --- */
  .sm-blog-header {
    text-align: center;
    margin-bottom: 40px;
    padding-top: 40px; /* Added internal top spacing for the title since section padding is 0 */
  }
  .sm-blog-title {
    font-family: 'Poppins', sans-serif;
    font-weight: 800; /* Extra Bold */
    font-size: 28px;
    color: #1f1f1f;
    margin: 0;
  }

  /* --- GRID --- */
  .sm-blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    margin-bottom: 50px;
  }

  /* --- CARD --- */
  .sm-blog-card {
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08); /* Soft Shadow */
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  
  .sm-blog-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.12);
  }

  /* Image */
  .sm-blog-img-wrap {
    width: 100%;
    height: 220px; /* Fixed height for consistency */
    overflow: hidden;
    background-color: #f4f4f4;
  }
  
  .sm-blog-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  
  .sm-blog-card:hover .sm-blog-img {
    transform: scale(1.05);
  }

  /* Text Content */
  .sm-blog-info {
    padding: 25px 20px;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
  }
  
  .sm-blog-name {
    font-family: 'Poppins', sans-serif;
    font-weight: 700;
    font-size: 18px;
    color: #1f1f1f;
    line-height: 1.4;
    margin: 0;
  }

  /* --- BOTTOM BUTTON --- */
  .sm-blog-footer {
    text-align: center;
    padding-bottom: 20px; /* Extra space before section ends */
  }
  
  .sm-blog-btn {
    display: inline-block;
    background-color: #2D2D2D; /* Dark Charcoal */
    color: #ffffff;
    font-family: 'Poppins', sans-serif;
    font-weight: 700;
    font-size: 14px;
    text-transform: uppercase;
    text-decoration: none;
    padding: 16px 50px;
    border-radius: 6px;
    transition: background-color 0.2s ease;
    letter-spacing: 0.5px;
  }
  
  .sm-blog-btn:hover {
    background-color: #000000;
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .sm-blog-inner { padding: 0 40px; }
    .sm-blog-grid { gap: 20px; }
  }

  @media (max-width: 768px) {
    .sm-blog-section { padding: 0 0 5px; }
    .sm-blog-inner { padding: 0 20px; }
    .sm-blog-grid { grid-template-columns: 1fr; gap: 25px; }
    .sm-blog-title { font-size: 24px; }
    .sm-blog-header { padding-top: 30px; }
  }
</style>

<div class="sm-blog-section">
  <div class="sm-blog-inner">
    
    {% if section.settings.heading != blank %}
      <div class="sm-blog-header">
        <h2 class="sm-blog-title">{{ section.settings.heading }}</h2>
      </div>
    {% endif %}

    <div class="sm-blog-grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="sm-blog-card" {{ block.shopify_attributes }}>
          <div class="sm-blog-img-wrap">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title }}" class="sm-blog-img" loading="lazy">
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'sm-blog-img' }}
            {% endif %}
          </div>
          <div class="sm-blog-info">
            <h3 class="sm-blog-name">{{ block.settings.title }}</h3>
          </div>
        </a>
      {% endfor %}
    </div>

    <div class="sm-blog-footer">
      <a href="{{ section.settings.btn_link }}" class="sm-blog-btn">
        {{ section.settings.btn_label }}
      </a>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Blog Posts Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Learn More About Bras In Our Blog"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "VISIT OUR BLOG"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "article",
      "name": "Blog Post",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Article Title",
          "default": "How To Find Your Bra Size"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Article Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blog Posts Grid",
      "blocks": [
        { "type": "article", "settings": { "title": "How To Find Your Bra Size" } },
        { "type": "article", "settings": { "title": "Top 11 Types of Bras" } },
        { "type": "article", "settings": { "title": "A Complete Guide To Bra Cup" } }
      ]
    }
  ]
}
{% endschema %}