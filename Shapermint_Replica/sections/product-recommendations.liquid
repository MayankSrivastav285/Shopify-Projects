{% comment %}
  SHAPERMINT REPLICA: MANUAL PRODUCT GRID V8 (PIXEL PERFECT COLORS)
  - COLORS: Updated to match Shapermint's source code (#292929, #C64844, #F2D96F).
  - MOBILE: Retains the V7 layout (3/4.5 ratio, 5px padding, aligned prices).
{% endcomment %}

<style>
  .sm-rec-section {
    padding: 5px 0;
    background-color: #fff;
    border-bottom: 1px solid #f0f0f0;
  }

  .sm-rec-inner {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 160px;
  }

  /* Heading */
  .sm-rec-heading {
    text-align: center;
    font-family: 'Poppins', sans-serif;
    font-weight: 700; /* Matches Avenir Bold */
    font-size: 28px;
    color: #292929; /* Shapermint Dark Grey */
    margin: 40px 0;
  }

  /* Grid */
  .sm-rec-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
  }

  /* Card */
  .sm-rec-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    position: relative;
    height: 100%;
  }

  /* Image Area */
  .sm-rec-img-wrap {
    width: 100%;
    aspect-ratio: 4/5;
    position: relative;
    overflow: hidden;
    background: #f4f4f4;
    border-radius: 4px;
    margin-bottom: 12px;
  }

  .sm-rec-img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.3s ease;
  }
  .sm-rec-card:hover .sm-rec-img { transform: scale(1.05); }

  /* --- BADGES (Exact Colors) --- */
  .sm-badge-top {
    position: absolute; top: 0; left: 0;
    font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 11px;
    padding: 5px 10px; border-bottom-right-radius: 4px;
    z-index: 2;
  }

  .sm-badge-bottom {
    position: absolute; bottom: 10px; left: 0;
    font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 10px;
    padding: 4px 8px; text-transform: uppercase;
    display: flex; align-items: center; gap: 4px;
    border-top-right-radius: 4px; border-bottom-right-radius: 4px;
    z-index: 2;
  }

  /* Info */
  .sm-rec-info {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .sm-rec-title {
    font-family: 'Montserrat', sans-serif; 
    font-size: 15px; 
    font-weight: 600; /* Matches Avenir Demi */
    color: #292929; 
    margin: 0 0 6px; 
    line-height: 1.4; 
    text-align: center;
  }

  .sm-rec-price-row {
    display: flex; align-items: center; justify-content: center;
    gap: 8px; font-family: 'Montserrat', sans-serif;
    margin-top: auto;
  }
  .sm-rec-old { 
    text-decoration: line-through; 
    color: #999; /* Standard Grey */
    font-size: 13px; 
  }
  
  .sm-rec-new { 
    font-weight: 700; /* Bold Price */
    font-size: 18px; 
    color: #292929; 
    display: flex; align-items: flex-start; 
  }
  .sm-rec-new span { font-size: 11px; margin-top: 2px; }

  .sm-rec-stars {
    display: flex; justify-content: center; align-items: center; gap: 4px;
    margin-top: 6px; font-size: 12px; color: #666; font-family: 'Montserrat', sans-serif;
  }
  .sm-star-icon { color: #F2D96F; font-size: 14px; } /* Shapermint Star Yellow */

  /* --- RESPONSIVE FIXES --- */
  @media (max-width: 1200px) { .sm-rec-inner { padding: 0 40px; } }
  
  @media (max-width: 900px) {
    .sm-rec-inner { padding: 0 15px; }
    .sm-rec-grid { 
      grid-template-columns: repeat(2, 1fr); 
      gap: 12px; 
    }
    .sm-rec-heading { font-size: 24px; margin-bottom: 20px; margin-top: 25px; }

    /* Taller Images on Mobile */
    .sm-rec-img-wrap {
      aspect-ratio: 3/4.8; 
    }

    /* Strict Title Alignment (2 Lines) */
    .sm-rec-title {
      font-size: 13px;
      line-height: 1.4;
      height: 38px; 
      margin-bottom: 8px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    
    .sm-rec-new { font-size: 16px; }
    .sm-rec-old { font-size: 12px; }
  }
</style>

<div class="sm-rec-section">
  <div class="sm-rec-inner">
    <h2 class="sm-rec-heading">{{ section.settings.heading }}</h2>

    <div class="sm-rec-grid">
      {% for block in section.blocks %}
        {% assign product = all_products[block.settings.product] %}
        
        {% if product != blank %}
          <a href="{{ product.url }}" class="sm-rec-card" {{ block.shopify_attributes }}>
            <div class="sm-rec-img-wrap">
              
              {% if block.settings.top_badge_text != blank %}
                <div class="sm-badge-top" 
                     style="background-color: {{ block.settings.top_badge_bg }}; color: {{ block.settings.top_badge_text_color }};">
                  {{ block.settings.top_badge_text }}
                </div>
              {% endif %}
              
              <img src="{{ product.featured_image | image_url: width: 600 }}" class="sm-rec-img" alt="{{ product.title }}" loading="lazy">
              
              {% if block.settings.bottom_badge_text != blank %}
                <div class="sm-badge-bottom" 
                     style="background-color: {{ block.settings.bottom_badge_bg }}; color: {{ block.settings.bottom_badge_text_color }};">
                  {% if block.settings.show_lightning %}
                    <svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                  {% endif %}
                  {{ block.settings.bottom_badge_text }}
                </div>
              {% endif %}
            </div>

            <div class="sm-rec-info">
              <h3 class="sm-rec-title">{{ product.title }}</h3>
              
              <div class="sm-rec-price-row">
                <span class="sm-rec-old">{{ product.compare_at_price | money }}</span>
                <div class="sm-rec-new">
                  <span>{{ cart.currency.symbol }}</span>
                  {{ product.price | money_without_currency | split: '.' | first }}
                  <span>{{ product.price | money_without_currency | split: '.' | last }}</span>
                </div>
              </div>
              
              <div class="sm-rec-stars">
                <span class="sm-star-icon">★★★★★</span> ({{ product.reviews_count | default: 850 }})
              </div>
            </div>
          </a>
        {% else %}
          <div class="sm-rec-card">
            <div class="sm-rec-img-wrap">
              <div class="sm-badge-top" style="background: #C64844; color: #fff;">Select Product</div>
              {{ 'product-1' | placeholder_svg_tag: 'sm-rec-img' }}
            </div>
            <div class="sm-rec-info">
              <h3 class="sm-rec-title">Select a product in block settings</h3>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Manual Product Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "You Will Also Love"
    }
  ],
  "blocks": [
    {
      "type": "product_item",
      "name": "Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "header",
          "content": "Top Badge Settings"
        },
        {
          "type": "text",
          "id": "top_badge_text",
          "label": "Text",
          "default": "Valentine's Day Sale"
        },
        {
          "type": "color",
          "id": "top_badge_bg",
          "label": "Background Color",
          "default": "#C64844"
        },
        {
          "type": "color",
          "id": "top_badge_text_color",
          "label": "Text Color",
          "default": "#ffffff"
        },
        {
          "type": "header",
          "content": "Bottom Badge Settings"
        },
        {
          "type": "text",
          "id": "bottom_badge_text",
          "label": "Text",
          "default": "BEST SELLER"
        },
        {
          "type": "checkbox",
          "id": "show_lightning",
          "label": "Show Lightning Icon",
          "default": false
        },
        {
          "type": "color",
          "id": "bottom_badge_bg",
          "label": "Background Color",
          "default": "#F2D96F"
        },
        {
          "type": "color",
          "id": "bottom_badge_text_color",
          "label": "Text Color",
          "default": "#292929"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Manual Product Grid",
      "blocks": [
        { 
          "type": "product_item",
          "settings": { 
            "bottom_badge_text": "SELLING FAST",
            "show_lightning": true,
            "bottom_badge_bg": "#F2D96F"
          }
        },
        { 
          "type": "product_item",
          "settings": { 
            "bottom_badge_text": "BEST SELLER",
            "show_lightning": false,
            "bottom_badge_bg": "#ffffff"
          }
        },
        { 
          "type": "product_item",
          "settings": { 
            "bottom_badge_text": "SELLING FAST",
            "show_lightning": true,
            "bottom_badge_bg": "#F2D96F"
          }
        },
        { 
          "type": "product_item",
          "settings": { 
            "bottom_badge_text": "BEST SELLER",
            "show_lightning": false,
            "bottom_badge_bg": "#ffffff"
          }
        }
      ]
    }
  ]
}
{% endschema %}