{% comment %}
  CUSTOM BEST SELLERS (FINAL: REDUCED TOP PADDING)
  - PADDING: Top reduced to 15px (was 50px).
  - PADDING: Sides 50px, Bottom 50px.
{% endcomment %}

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
  /* MATCHING CONTAINER WIDTH EXACTLY */
  .bs-section {
    /* FIX: Top padding decreased to 15px */
    padding: 24px 24px 24px 24px;
    background: #ffffff;
    text-align: center;
    max-width: 1200px; 
    margin: 0 auto;    
  }

  .bs-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 24px;
    font-weight: 700;
    color: #000;
    margin-bottom: 30px; 
    line-height: 32px;
  }

  /* --- GRID SYSTEM --- */
  .bs-grid {
    display: grid;
    gap: 24px; 
    width: 100%;
    grid-template-columns: repeat(4, 1fr); 
  }

  /* TABLET (3 Columns) */
  @media (max-width: 1100px) {
    .bs-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* MOBILE (2 Columns) */
  @media (max-width: 700px) {
    .bs-grid {
      grid-template-columns: repeat(2, 1fr); 
      gap: 12px; 
    }
    .bs-title { font-size: 22px; margin-bottom: 20px; }
    /* Revert padding on mobile so it's not too squished */
    .bs-section { padding: 30px 20px; }
  }

  /* --- PRODUCT CARD --- */
  .bs-card {
    background: #fff;
    text-align: center;
    text-decoration: none;
    color: inherit;
    position: relative;
    border-radius: 0px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    cursor: pointer;
    display: flex;
    flex-direction: column;
  }

  .bs-card:hover {
    transform: translateY(-5px); 
    box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    z-index: 2;
  }

  .bs-img-wrap {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 12px;
    aspect-ratio: 3.9 / 5.1; 
    background: #f4f4f4;
  }

  .bs-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* --- BADGES --- */
  .bs-badge-top {
    position: absolute; top: 0; left: 0;
    background: {{ settings.global_sale_bg | default: '#C75C54' }};
    color: {{ settings.global_sale_text_color | default: '#ffffff' }};
    font-family: 'Montserrat', sans-serif;
    font-size: 10px; font-weight: 700;
    padding: 5px 10px;
    text-transform: uppercase;
    border-bottom-right-radius: 6px;
    z-index: 2;
  }

  .bs-badge-bottom {
    position: absolute; bottom: 8px; left: 8px;
    background: #F8E71C; color: #000;
    font-family: 'Montserrat', sans-serif;
    font-size: 9px; font-weight: 800;
    padding: 4px 8px;
    text-transform: uppercase;
    display: flex; align-items: center; gap: 4px;
    border-radius: 2px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    z-index: 2;
  }
  .bolt-icon { width: 10px; height: 10px; }

  /* --- TEXT INFO --- */
  .bs-info { padding: 0 5px; flex: 1; display: flex; flex-direction: column; }

  .bs-prod-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #000;
    margin-bottom: 4px;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 36px; 
  }

  @media (max-width: 700px) {
    .bs-prod-title { font-size: 12px; min-height: 34px; }
  }

  .bs-price-area {
    display: flex; justify-content: center; align-items: baseline; gap: 6px;
    margin-bottom: 6px;
    font-family: 'Montserrat', sans-serif;
  }

  .bs-compare {
    text-decoration: line-through;
    color: #999;
    font-size: 12px;
  }

  .bs-price {
    color: #000;
    font-weight: 700;
    font-size: 16px;
  }

  /* REVIEWS */
  .bs-reviews {
    display: flex; justify-content: center; align-items: center; gap: 4px;
    font-size: 11px; color: #666;
    margin-top: auto; 
  }
  .bs-stars { color: #E3C065; letter-spacing: 1px; font-size: 13px; }

  /* SHOP ALL BUTTON */
  .bs-btn-wrap { margin-top: 40px; }
  .bs-btn {
    background: #EAA993;
    color: #000;
    font-family: 'Montserrat', sans-serif;
    font-size: 13px; font-weight: 700;
    padding: 14px 50px;
    text-decoration: none;
    border-radius: 4px;
    text-transform: uppercase;
    transition: 0.2s;
    display: inline-block;
  }
  .bs-btn:hover { background: #d69580; }
</style>

<div class="bs-section">
  <h2 class="bs-title">{{ section.settings.title }}</h2>

  <div class="bs-grid">
    {% for product in section.settings.product_list %}
      <a href="{{ product.url }}" class="bs-card">
        
        <div class="bs-img-wrap">
          <img src="{{ product.featured_image | image_url: width: 600 }}" class="bs-img" alt="{{ product.title }}">
          
          {% if settings.global_sale_text != blank %}
            <div class="bs-badge-top">{{ settings.global_sale_text }}</div>
          {% endif %}

          {% if product.tags contains 'Fast' %}
            <div class="bs-badge-bottom">
              <svg class="bolt-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg>
              SELLING FAST
            </div>
          {% else %}
            <div class="bs-badge-bottom" style="background:#fff; border:1px solid #eee;">BEST SELLER</div>
          {% endif %}
        </div>

        <div class="bs-info">
          <div class="bs-prod-title">{{ product.title }}</div>
          
          <div class="bs-price-area">
            {% if product.compare_at_price > product.price %}
              <span class="bs-compare">{{ product.compare_at_price | money }}</span>
            {% endif %}
            <span class="bs-price">{{ product.price | money }}</span>
          </div>

          <div class="bs-reviews">
            <span class="bs-stars">★★★★★</span>
            <span>(12,518)</span>
          </div>
        </div>

      </a>
    {% else %}
      <p style="grid-column: 1 / -1; color: #999;">Please select products in the Customizer.</p>
    {% endfor %}
  </div>

  <div class="bs-btn-wrap">
    <a href="{{ section.settings.btn_link }}" class="bs-btn">Shop All</a>
  </div>
</div>

{% schema %}
{
  "name": "Best Sellers (Custom)",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Our Best Sellers"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Select 4 Products",
      "limit": 4
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Shop All Button Link"
    }
  ],
  "presets": [
    {
      "name": "Best Sellers (Custom)"
    }
  ]
}
{% endschema %}